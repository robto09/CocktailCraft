	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Privacy Usage Descriptions -->
	<key>NSNetworkVolumesUsageDescription</key>
	<string>CocktailCraft needs network access to fetch cocktail recipes and images.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>CocktailCraft may access local network for enhanced functionality.</string>
	<!-- Background Modes: `fetch` backs BGAppRefreshTask, `processing` backs
	     BGProcessingTask (the previous `background-app-refresh` /
	     `background-fetch` strings are not recognized UIBackgroundModes
	     values). Every identifier BGTaskScheduler.register is called with
	     must also appear in BGTaskSchedulerPermittedIdentifiers, or
	     registration fails at runtime and background sync never runs. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.cocktailcraft.background-refresh</string>
		<string>com.cocktailcraft.background-fetch</string>
	</array>
	<!-- Deep links from the home-screen widgets:
	     cocktailcraft://cocktail/{id} (see WidgetBridge.swift) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.cocktailcraft.CocktailCraft</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>cocktailcraft</string>
			</array>
		</dict>
	</array>
	<!-- iOS 18.5 Compatibility -->
	<key>NSSupportsLiveActivities</key>
	<false/>
	<key>NSUserTrackingUsageDescription</key>
	<string>CocktailCraft respects your privacy and does not track users across apps.</string>
	<!-- TLS certificate pinning for TheCocktailDB (defense-in-depth). The site
	     is fronted by Cloudflare Universal SSL, which rotates issuing CAs
	     between Google Trust Services, Let's Encrypt, and SSL.com at ~90-day
	     renewals — so this pins the ROOTS of that whole CA pool (plus the GTS
	     intermediate observed live), never the leaf. Captured 2026-07-08 from
	     the live chain + the Mozilla root store. Keep in sync with the pin-set
	     in androidApp/src/main/res/xml/network_security_config.xml. Unlike the
	     Android config there is no expiration: if Cloudflare adds a CA to its
	     pool, requests fail until these pins are refreshed
	     (openssl s_client -connect www.thecocktaildb.com:443 -showcerts). -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSPinnedDomains</key>
		<dict>
			<key>thecocktaildb.com</key>
			<dict>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSPinnedCAIdentities</key>
