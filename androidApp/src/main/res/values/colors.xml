<?xml version="1.0" encoding="utf-8"?>
<!--
    Mirrors the Compose palette in ui/theme/Theme.kt (AppColors), which is the
    single source of truth. These values only cover the pre-Compose window
    (cold start, status bar) and the home-screen widget assets — if AppColors
    changes, update the matching entry here.
-->
<resources>
    <!-- AppColors.PrimaryLight / PrimaryDark (coral) -->
    <color name="cocktail_primary">#EB6A43</color>
    <color name="cocktail_primary_dark">#FF8A65</color>

    <!-- AppColors.SecondaryLight / SecondaryDark (gold) -->
    <color name="cocktail_secondary">#FFC84D</color>
    <color name="cocktail_secondary_dark">#FFD180</color>

    <!-- AppColors.BackgroundLight / BackgroundDark -->
    <color name="background_light">#FAFAFA</color>
    <color name="background_dark">#121212</color>

    <!-- AppColors.SurfaceLight / SurfaceDark -->
    <color name="surface_light">#FFFFFF</color>
    <color name="surface_dark">#1E1E1E</color>

    <!-- AppColors.TextPrimaryLight / TextPrimaryDark -->
    <color name="text_primary_light">#000000</color>
    <color name="text_primary_dark">#FFFFFF</color>

    <!-- AppColors.TextSecondaryLight / TextSecondaryDark -->
    <color name="text_secondary_light">#8E8E93</color>
    <color name="text_secondary_dark">#B0B0B0</color>

    <!-- AppColors status colors -->
    <color name="success">#34C759</color>
    <color name="error">#FF3B30</color>
    <color name="warning">#FF9500</color>

    <!-- System Colors -->
    <color name="black">#000000</color>
    <color name="white">#FFFFFF</color>
</resources>
