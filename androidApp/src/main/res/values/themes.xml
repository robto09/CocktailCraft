<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-Compose window styling only: the runtime look is
    AnimatedCocktailBarTheme (ui/theme/AnimatedTheme.kt), which runs
    edge-to-edge with a transparent status bar over the app background.
    Keep window background / status bar in step with AppColors so the
    cold-start frame matches the composed UI. Dark values live in
    values-night/themes.xml.
-->
<resources>
    <!-- Base application theme -->
    <style name="Theme.CocktailBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/cocktail_primary</item>
        <item name="colorPrimaryDark">@color/cocktail_primary</item>
        <item name="colorAccent">@color/cocktail_secondary</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:colorBackground">@color/background_light</item>

        <!-- Status bar: app background under the (edge-to-edge) bar, dark icons -->
        <item name="android:statusBarColor">@color/background_light</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary_light</item>
        <item name="android:textColorSecondary">@color/text_secondary_light</item>
    </style>
</resources>
