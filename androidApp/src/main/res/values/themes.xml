<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.CocktailBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/cocktail_primary</item>
        <item name="colorPrimaryDark">@color/cocktail_primary_dark</item>
        <item name="colorAccent">@color/cocktail_accent</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:colorBackground">@color/background_light</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/cocktail_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary_light</item>
        <item name="android:textColorSecondary">@color/text_secondary_light</item>
    </style>

    <!-- Dark theme -->
    <style name="Theme.CocktailBar.Dark" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/cocktail_primary_light</item>
        <item name="colorPrimaryDark">@color/cocktail_primary</item>
        <item name="colorAccent">@color/cocktail_accent_light</item>

        <!-- Background colors -->
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
    </style>
</resources>