<?xml version="1.0" encoding="utf-8"?>
<!-- Backup/transfer rules for API 31+. Keep in sync with backup_rules.xml (API 24-30).
     cocktailcraft_prefs.xml holds credentials and PII (users, password hashes, orders
     with addresses) and must never leave the device via backup or transfer.
     cocktailcraft_secure_prefs.xml is Keystore-encrypted; its master key is not backed
     up, so restored copies are unreadable and would only corrupt a fresh install. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="cocktailcraft_prefs.xml" />
        <exclude domain="sharedpref" path="cocktailcraft_secure_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="cocktailcraft_prefs.xml" />
        <exclude domain="sharedpref" path="cocktailcraft_secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
