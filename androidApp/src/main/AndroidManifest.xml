<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.cocktailcraft.android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".CocktailCraftApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CocktailBar">
        <!-- singleTop so widget deep links reach a running instance via
             onNewIntent (forwarded to the NavController in MainScreen)
             instead of stacking a duplicate activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.CocktailBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Cocktail detail deep link: app://cocktailcraft/cocktail/{id}
                 (COCKTAIL_DEEP_LINK_BASE_PATH in navigation/Routes.kt) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="app"
                    android:host="cocktailcraft"
                    android:pathPrefix="/cocktail/" />
            </intent-filter>
        </activity>

        <!-- Random Cocktail Widget -->
        <receiver
            android:name=".widget.RandomCocktailWidgetReceiver"
            android:exported="true"
            android:label="@string/random_cocktail_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/random_cocktail_widget_info" />
        </receiver>

        <!-- Favorites Widget -->
        <receiver
            android:name=".widget.FavoritesWidgetReceiver"
            android:exported="true"
            android:label="@string/favorites_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/favorites_widget_info" />
        </receiver>

        <!-- Disable WorkManager's automatic initializer so the Application's
             Configuration.Provider (Koin WorkerFactory, AN-10) is consulted. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>