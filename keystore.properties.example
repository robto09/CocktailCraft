# Release signing credentials — copy to keystore.properties (gitignored) and fill in.
# CI can instead supply the equivalent environment variables:
#   ANDROID_RELEASE_STORE_FILE / ANDROID_RELEASE_STORE_PASSWORD /
#   ANDROID_RELEASE_KEY_ALIAS / ANDROID_RELEASE_KEY_PASSWORD
# Generate a keystore with:
#   keytool -genkeypair -keystore androidApp/release.keystore -alias cocktailcraft-release \
#     -keyalg RSA -keysize 4096 -validity 10950
storeFile=androidApp/release.keystore
storePassword=changeme
keyAlias=cocktailcraft-release
keyPassword=changeme
